{
  "manifest_version": 3,
  "name": "Briefer",
  "description": "Instantly summarize articles, YouTube videos, Coursera & DeepLearning.AI courses — TLDR, key points, AI sketchnote.",
  "version": "1.0.0",
  "homepage_url": "https://briefer.steepworksai.com/",
  "permissions": ["activeTab", "storage", "scripting", "sidePanel", "tabs", "windows"],
  "host_permissions": ["<all_urls>", "https://generativelanguage.googleapis.com/"],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/panel/index.html"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/whiteboard/index.html", "src/preview/index.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
